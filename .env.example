# Umgebungsvariablen für Theodor Litt Login-System
# Diese Datei kopieren nach: .env
# und dann Ihre echten Werte eintragen!

# SSH-Server Konfiguration (ALLE DATEN WERDEN AUF DEM SERVER GESPEICHERT!)
SSH_REMOTE_HOST=100.66.170.64
SSH_REMOTE_USER=dataserver
SSH_REMOTE_PATH=/srv/schuler-daten

# Flask Secret Key (ÄNDERN SIE DIES!)
