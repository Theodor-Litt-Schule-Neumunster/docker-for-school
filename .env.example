# Umgebungsvariablen für DockerLab Login-System
# Diese Datei kopieren nach: .env
# und dann Ihre echten Werte eintragen!

# SSH-Server Konfiguration
SSH_REMOTE_HOST=192.168.178.1
SSH_REMOTE_USER=dataserver
SSH_REMOTE_PATH=/srv/schuler-daten

# Flask Secret Key (ÄNDERN SIE DIES!)
# Generieren Sie einen zufälligen Wert mit:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=secret-change-in-production

# Optional: Für Debugging (nicht in Produktion verwenden!)
# FLASK_DEBUG=1
