# DockerLab Konfiguration

# Secret Key für Flask (in Produktion ändern!)
SECRET_KEY=dockerlab-secret-key-change-in-production

# Nextcloud Konfiguration (optional - nur für Sync-Funktion)
# Leer lassen, wenn keine Nextcloud-Synchronisation gewünscht
NEXTCLOUD_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_PATH=/DockerLab

# Beispiel mit aktivierter Nextcloud:
# NEXTCLOUD_URL=https://cloud.example.com
# NEXTCLOUD_USERNAME=my-username
# NEXTCLOUD_PASSWORD=my-app-password
# NEXTCLOUD_PATH=/DockerLab
