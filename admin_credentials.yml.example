# Admin-Credentials für Theodor Litt Login-System
# Diese Datei muss auf dem SSH-Server liegen!
# 
# Pfad auf Server: /srv/schuler-daten/admin_credentials.yml
# 
# WICHTIG: 
# - Diese Datei NICHT in Git einchecken!
# - Nur Server-Admins sollten Zugriff haben
# - Verwenden Sie `chmod 600` auf dem Server für maximale Sicherheit

admins:
  # Beispiel-Admin 1 (mit Passwort-Hash - EMPFOHLEN)
  - username: "admin"
    password_hash: "scrypt:32768:8:1$abc123..."  # Generiert mit werkzeug.security.generate_password_hash()
    email: "admin@theodor-litt.de"
    description: "Haupt-Administrator"

  # Beispiel-Admin 2 (mit Klartext-Passwort - NUR FÜR TESTS)
  - username: "lehrer.mueller"
    password: "GeheimesPasswort123!"  # WARNUNG: Nicht sicher! Nur für Tests/Entwicklung
    email: "mueller@theodor-litt.de"
    description: "Lehrer mit Admin-Rechten"

# Wie man einen sicheren Passwort-Hash generiert:
# 
# Python-Code:
# >>> from werkzeug.security import generate_password_hash
# >>> generate_password_hash("MeinPasswort123!")
# 'scrypt:32768:8:1$...'
#
# Oder verwenden Sie dieses Hilfsskript:
# python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash(input('Passwort: ')))"
